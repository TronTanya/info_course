# =============================================================================
# Production compose — шаблон для подстановки в docker-compose.prod.yml
# (не коммитьте реальные секреты; только placeholder-значения ниже).
#
# Локальная проверка compose без warnings:
#   ./scripts/compose-prod-config.sh
#   # или:
#   docker compose --env-file .env.prod.example -f docker-compose.prod.yml config
#
# На VPS:
#   cp .env.prod.example .env.production
#   chmod 600 .env.production
#   # замените CHANGE_ME_* и your-domain.example
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
#
# Генерация секретов: openssl rand -base64 32  |  openssl rand -hex 32
# =============================================================================

# --- Публичные URL (ваш домен) ---
AUTH_URL=https://your-domain.example
NEXT_PUBLIC_APP_URL=https://your-domain.example
NEXT_PUBLIC_API_URL=https://your-domain.example
CORS_ORIGINS=https://your-domain.example

# --- PostgreSQL (только внутри Docker-сети) ---
POSTGRES_USER=cyberedu
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD
POSTGRES_DB=cyberedu

# --- Auth / JWT (≥32 символа, уникальные) ---
AUTH_SECRET=CHANGE_ME_AUTH_SECRET_MIN_32_CHARS
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET_MIN_32_CHARS

# --- Backend internal API (заголовок X-API-Key) ---
INTERNAL_API_KEY=CHANGE_ME_INTERNAL_API_HEX

# --- Redis (обязателен в production compose) ---
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# --- AI (опционально) ---
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Runtime (не секреты) ---
ENVIRONMENT=production
NODE_ENV=production
UVICORN_WORKERS=2
AUTH_SESSION_MAX_AGE=172800
SHOW_SEED_LOGIN_HINT=0
TRUSTED_PROXY=1
RUN_SEED=0
SECURITY_AUDIT_DB=1

# --- Порты на хосте (Nginx) ---
HTTP_PORT=80
HTTPS_PORT=443

# --- Сборка frontend (при необходимости зеркала Docker Hub) ---
NODE_IMAGE=node:20-bookworm-slim
