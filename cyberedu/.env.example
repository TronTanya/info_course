# Скопируйте в cyberedu/.env при необходимости переопределить значения для docker compose.
# Запуск приложения — только через `docker compose` из этого каталога (см. README.md).
# Подробные комментарии по переменным — в:
#   frontend/.env.example  — Next.js, Prisma, AI, AUTH
#   backend/.env.example   — FastAPI, JWT, DATABASE_URL

AUTH_SECRET=dev-secret-change-me-in-production-min-32-chars
JWT_SECRET_KEY=dev-secret-change-me-in-production-min-32-chars!!

# Dev-only: Postgres / internal API (не использовать в production)
POSTGRES_PASSWORD=cyberedu_dev_password
INTERNAL_API_KEY=cyberedu-dev-internal-api-key-change-me

# Первый запуск с демо-данными (admin/student): RUN_SEED=1 docker compose up --build
# Production: всегда RUN_SEED=0 — демо-учётки запрещены
RUN_SEED=0

# Сайт по умолчанию: http://localhost:3100 (проброс в docker-compose.yml: 3100:3000).
# Не запускайте одновременно контейнер `frontend` и `npm run dev` на одном и том же порту 3100.
# Если открываете сайт с другого устройства по IP, задайте тот же URL, что в адресной строке:
# AUTH_URL=http://192.168.1.10:3100
# NEXT_PUBLIC_APP_URL=http://192.168.1.10:3100
AUTH_URL=http://localhost:3100
NEXT_PUBLIC_APP_URL=http://localhost:3100

# Базовый образ Node для сборки frontend (если Docker Hub недоступен — зеркало или свой registry):
# NODE_IMAGE=node:20-bookworm-slim

# --- AI (подхватывается сервисом frontend в docker compose) ---
# DeepSeek (OpenAI-совместимый): скопируйте блок в .env и подставьте ключ с https://platform.deepseek.com/
# OPENAI_API_KEY=sk-...
# OPENAI_API_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# После запуска compose с Redis (профиль cache):
# REDIS_URL=redis://redis:6379/0

# Скрыть демо-логины на странице входа: SHOW_SEED_LOGIN_HINT=0

# Persistent uploads (Docker compose задаёт UPLOADS_DIR=/app/uploads)
# UPLOADS_DIR=/app/uploads

# Production security
# ENVIRONMENT=production
# INTERNAL_API_KEY=openssl rand -hex 32
# TRUSTED_PROXY=1
# REDIS_URL=redis://redis:6379/0
# RUN_SEED=0
