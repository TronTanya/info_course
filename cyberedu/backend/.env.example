# === Обязательно для запуска FastAPI ===
# Строка подключения к PostgreSQL (драйвер psycopg v3)
DATABASE_URL=postgresql+psycopg://cyberedu:cyberedu_password@localhost:5432/cyberedu

# Секрет подписи JWT: минимум 32 символа (в production — уникальный случайный)
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32-minimum-length!!

# === Опционально ===
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Список origin фронтенда через запятую
CORS_ORIGINS=http://localhost:3100,http://127.0.0.1:3100

# Пропустить проверку SELECT 1 при старте (только unit-тесты)
# SKIP_DB_LIFESPAN_CHECK=1

# Redis — при запуске compose с профилем cache
# REDIS_URL=redis://localhost:6379/0
