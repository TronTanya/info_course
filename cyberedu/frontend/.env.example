# =============================================================================
# Полный стек запускается только через Docker (см. cyberedu/README.md).
# В контейнере `frontend` переменные задаёт docker-compose.yml (этот файл не обязателен для compose).
#
# Скопируйте в frontend/.env только если:
#   - запускаете `npx prisma …` с хоста к Postgres из compose, или
#   - отлаживаете Next вне Docker (не рекомендуется).
# =============================================================================

# Prisma / Next: только `postgresql://` или `postgres://`. Строка `postgresql+psycopg://` из backend
# автоматически приводится к `postgresql://` при старте Next (`instrumentation.ts`) и в `prisma/seed.ts`.
DATABASE_URL="postgresql://cyberedu:cyberedu_dev_password@127.0.0.1:15432/cyberedu?schema=public"

# Внутри Docker-сети (справочно; в compose уже задано):
# postgresql://cyberedu:cyberedu_password@postgres:5432/cyberedu?schema=public

# Секрет NextAuth (≥32 символа). Должен совпадать между перезапусками и с тем, что в Docker compose,
# иначе cookie сессии не расшифруется (ошибка «no matching decryption secret»). Значение по умолчанию — как в compose.
AUTH_SECRET="dev-secret-change-me-in-production-min-32-chars"

# URL в браузере — должен совпадать с тем, что вы открываете (compose: http://localhost:3100)
AUTH_URL="http://localhost:3100"
NEXT_PUBLIC_APP_URL="http://localhost:3100"

# FastAPI с хоста (compose пробрасывает backend на 18000)
NEXT_PUBLIC_API_URL="http://localhost:18000"

# === AI (DeepSeek и др. с OpenAI-совместимым API) ===
# В Docker ключ и URL лучше задавать в cyberedu/.env (см. ../.env.example) — compose пробросит в контейнер frontend.
OPENAI_API_KEY=
# AI_API_KEY=
# DeepSeek (пример):
# OPENAI_API_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# === PDF сертификата (опционально) ===
# CERTIFICATE_ORG_LINE=
# CERTIFICATE_SIGNATORY_LINE=

# === Security (production) ===
# TRUSTED_PROXY=1
# REDIS_URL=redis://localhost:6379/0
# AUTH_SESSION_MAX_AGE=172800
# SECURITY_AUDIT_DB=1
# RUN_SEED=0
