{
  "name": "cyberedu-frontend",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev --port 3100",
    "build": "next build",
    "start": "next start --port 3100",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:security": "vitest run tests/security-*.test.ts tests/middleware-rate-limit.test.ts tests/server-action-rate-limit.test.ts tests/submit-actions-rate-limit.test.ts tests/security-submit-production.test.ts tests/rate-limit-service.test.ts",
    "test:rate-limit:redis": "vitest run tests/rate-limit-redis.integration.test.ts",
    "check:rate-limit": "bash ../scripts/check-rate-limit-production.sh",
    "test:watch": "vitest",
    "test:e2e": "ENVIRONMENT=test E2E_USE_SEED_CREDENTIALS=1 playwright test",
    "test:e2e:smoke": "ENVIRONMENT=test E2E_USE_SEED_CREDENTIALS=1 playwright test --project=smoke",
    "test:e2e:a11y": "ENVIRONMENT=test E2E_USE_SEED_CREDENTIALS=1 playwright test --config=playwright.a11y.config.ts",
    "test:e2e:visual": "ENVIRONMENT=test E2E_USE_SEED_CREDENTIALS=1 playwright test --config=playwright.visual.config.ts",
    "test:e2e:visual:update": "ENVIRONMENT=test E2E_USE_SEED_CREDENTIALS=1 playwright test --config=playwright.visual.config.ts --update-snapshots",
    "test:e2e:live": "playwright test tests/prod-smoke/live-readonly.spec.ts",
    "test:e2e:ux": "ENVIRONMENT=test E2E_USE_SEED_CREDENTIALS=1 playwright test tests/e2e/auth-*.spec.ts tests/e2e/profile-portfolio.spec.ts tests/e2e/landing-public.spec.ts",
    "perf:lighthouse": "bash scripts/run-lighthouse-ci.sh",
    "perf:lighthouse:ci": "bash scripts/run-lighthouse-ci.sh",
    "test:e2e:prod": "ENVIRONMENT=production E2E_PRODUCTION_SMOKE=1 playwright test --config=playwright.prod.config.ts",
    "test:e2e:staging": "ENVIRONMENT=production E2E_PRODUCTION_SMOKE=1 playwright test --config=playwright.prod.config.ts",
    "test:e2e:prod:local": "bash ../scripts/e2e-prod-local.sh",
    "redis:ping": "node scripts/redis-ping.mjs",
    "screenshots": "ENVIRONMENT=test E2E_USE_SEED_CREDENTIALS=1 playwright test --config=playwright.screenshots.config.ts && node scripts/copy-screenshots-to-public.mjs",
    "smoke:url": "ENVIRONMENT=test E2E_USE_SEED_CREDENTIALS=1 playwright test tests/e2e/smoke.spec.ts",
    "smoke:local": "ALLOW_DEGRADED=1 bash ../scripts/staging-smoke.sh",
    "smoke:local:strict": "CHECK_REDIS=1 REDIS_URL=redis://127.0.0.1:6379 bash ../scripts/staging-smoke.sh",
    "smoke:local:e2e": "RUN_E2E=1 bash ../scripts/staging-smoke.sh",
    "smoke:prod-e2e": "cd .. && SMOKE_MODE=prod-e2e ./scripts/staging-smoke.sh",
    "smoke:staging": "cd .. && CHECK_REDIS=1 BASE_URL=http://127.0.0.1:3100 REDIS_URL=redis://127.0.0.1:6379 RUN_E2E=1 RUN_E2E_MODE=staging ./scripts/staging-smoke.sh",
    "smoke:staging:local": "bash ../scripts/e2e-prod-local.sh",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "seed": "prisma db seed",
    "seed:remote": "node scripts/seed-via-cli.mjs",
    "seed:retry": "powershell -ExecutionPolicy Bypass -File scripts/run-seed-retry.ps1",
    "seed:verify-password": "tsx scripts/verify-seed-password-preservation.ts",
    "certs:regenerate-pdf": "tsx scripts/regenerate-certificate-pdfs.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@fontsource/roboto": "^5.2.10",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@react-pdf/renderer": "^4.5.1",
    "@redis/client": "^5.12.1",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.106.2",
    "@tanstack/react-query": "^5.90.12",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "dejavu-fonts-ttf": "^2.37.3",
    "dotenv": "^17.4.2",
    "framer-motion": "^11.15.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.468.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^7.0.7",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.68.0",
    "recharts": "^3.5.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "redis": "^5.12.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.55.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "pg": "^8.21.0",
    "pg-copy-streams": "^7.0.0",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
